# Robinhood API Credentials
ROBINHOOD_USERNAME=your_robinhood_username
ROBINHOOD_PASSWORD=your_robinhood_password

# Market Data API Keys
FINNHUB_API_KEY=your_finnhub_api_key
TWELVE_DATA_API_KEY=your_twelve_data_api_key

# Free Data Source API Keys (Task 24)
NEWSAPI_KEY=your_newsapi_key
ALPHAVANTAGE_KEY=your_alphavantage_key
FRED_API_KEY=your_fred_api_key

# Email Configuration
SENDGRID_API_KEY=your_sendgrid_api_key
USER_EMAIL=your_email@example.com
RECIPIENT_EMAILS=recipient1@example.com,recipient2@example.com

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/investment_scout
REDIS_URL=redis://localhost:6379/0

# Cache TTL Configuration (in seconds)
ACTIVE_STOCK_TTL=15
WATCHLIST_STOCK_TTL=60
ROBINHOOD_TRADEABILITY_TTL=86400
COMPANY_INFO_TTL=86400
FINANCIAL_DATA_TTL=21600

# Newsletter Configuration
NEWSLETTER_HOUR=9
NEWSLETTER_MINUTE=0

# Alert Limits Configuration
MAX_TRADING_ALERTS_PER_DAY=3
ALERT_GENERATION_TIMEOUT=10
ALERT_DELIVERY_TIMEOUT=30

# Position Sizing Parameters (percentages)
LOW_RISK_MIN=15
LOW_RISK_MAX=25
MEDIUM_RISK_MIN=8
MEDIUM_RISK_MAX=15
HIGH_RISK_MIN=1
HIGH_RISK_MAX=8

# Application Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO
TIMEZONE=America/New_York

# Deployment Configuration (Task 26)
# Free Hosting Platform Settings
PORT=8000
WEB_CONCURRENCY=1
PYTHON_VERSION=3.11.0

# Free PostgreSQL Options (choose one):
# - ElephantSQL: https://www.elephantsql.com/ (20 MB free)
# - Supabase: https://supabase.com/ (500 MB free)
# - Neon: https://neon.tech/ (3 GB free)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Free Redis Options (choose one):
# - Redis Cloud: https://redis.com/try-free/ (30 MB free)
# - Upstash: https://upstash.com/ (10,000 commands/day free)
# REDIS_URL=redis://default:password@host:port

# SendGrid Free Tier (100 emails/day)
# Sign up: https://sendgrid.com/free/
# SENDGRID_API_KEY=your_sendgrid_api_key

# External Cron Service (for wake-up pings on free hosting)
# - cron-job.org: https://cron-job.org/ (free)
# Configure to ping: https://your-app.herokuapp.com/health every 25 minutes
HEALTH_CHECK_ENDPOINT=/health
